#!/usr/bin/env bash
#
# Pre-commit secret scanner for MeniscusMaximus.
# Blocks any commit whose staged changes contain credentials (GitHub tokens,
# Google API keys, OpenAI keys, private keys). This is what stops accidental
# leaks like the Config-file token.
#
# To bypass intentionally (rare): git commit --no-verify
#
set -uo pipefail

# Regexes for things that should never be committed.
SECRET_PATTERNS='github_pat_[A-Za-z0-9_]{20,}|ghp_[A-Za-z0-9]{30,}|gho_[A-Za-z0-9]{30,}|ghs_[A-Za-z0-9]{30,}|AIza[0-9A-Za-z_-]{30,}|sk-[A-Za-z0-9]{20,}|-----BEGIN[A-Z ]*PRIVATE KEY-----'

# Only look at lines being ADDED in this commit (ignore +++ file headers).
added_lines="$(git diff --cached --diff-filter=ACM -U0 | grep '^+' | grep -v '^+++' || true)"

hits="$(printf '%s\n' "$added_lines" | grep -E "$SECRET_PATTERNS" || true)"

if [ -n "$hits" ]; then
  echo ""
  echo "🚫  COMMIT BLOCKED — a possible secret was found in your staged changes:"
  echo ""
  printf '%s\n' "$hits" | sed -E 's/(github_pat_|ghp_|gho_|ghs_|AIza|sk-)[A-Za-z0-9_-]+/\1***REDACTED***/g'
  echo ""
  echo "Remove the secret (or unstage that file) and commit again."
  echo "If you are 100% sure this is a false positive: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
